{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals", "vitest"]
  },
  "include": [
    "e2e/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "fixtures/**/*.ts",
    "fixtures/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.ts",
    "vitest.shims.d.ts",
    ".storybook/**/*.ts",
    "prisma.config.*.ts",
    ".storybook/**/*.tsx",
    "playwright.config.ts",
    "react-router.config.ts",
    ".react-router/types/**/*.ts",
    ".react-router/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "coverage", ".gemini", ".claude", ".agents", ".vite", "storybook-static", "prisma/generated"]
}
